<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="FLaunch2.Views.AboutWindow"
		Icon="/Assets/FLaunch.ico"
		Width="400"
		Height="250"
		CanResize="False"
		CanMaximize="False"
		CanMinimize="False"
		WindowStartupLocation="CenterScreen"
		Title="AboutWindow">
	<StackPanel Margin="24" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
		<Image Source="/Assets/FLaunch.ico" Width="48" Height="48" HorizontalAlignment="Center" />
		<TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
		<TextBlock x:Name="VersionText" HorizontalAlignment="Center" />
		<TextBlock x:Name="CopyrightText" HorizontalAlignment="Center" Foreground="Gray" />
		<Button Content="OK" HorizontalAlignment="Center" HorizontalContentAlignment="Center" Width="100" Click="OnOkClicked" />
	</StackPanel>
</Window>