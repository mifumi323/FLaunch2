<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FLaunch2.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="30"
             x:Class="FLaunch2.Views.ItemView"
             x:DataType="vm:ItemViewModel"
             >
  <StackPanel Orientation="Horizontal">
    <Image Width="16" Height="16" Margin="5" Source="{Binding Icon}" />
    <TextBlock Margin="5" Text="{Binding DisplayName}" />
  </StackPanel>
</UserControl>
