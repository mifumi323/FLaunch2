<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:FLaunch2.ViewModels"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="420"
        x:Class="FLaunch2.Views.OptionWindow"
        x:DataType="vm:OptionViewModel"
        Icon="/Assets/FLaunch.ico"
        Width="420"
        Height="420"
        CanResize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterScreen"
        Title="オプション">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="OK" Width="75" IsDefault="True" HorizontalContentAlignment="Center" Click="OnOkClicked" />
      <Button Content="キャンセル" Width="75" IsCancel="True" HorizontalContentAlignment="Center" Click="OnCancelClicked" />
    </StackPanel>

    <StackPanel Spacing="12">
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
        <Label Grid.Row="0" Grid.Column="0" Content="初期スコア係数" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InitialScoreRate}" />

        <Label Grid.Row="1" Grid.Column="0" Content="スコア増加係数" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ScoreIncreaseRate}" />
      </Grid>

      <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="同値判定基準" FontWeight="Bold" />
          <CheckBox Content="表示名" IsChecked="{Binding ItemEquivalenceDisplayName}" />
          <CheckBox Content="実行ファイル" IsChecked="{Binding ItemEquivalenceFilePath}" />
          <CheckBox Content="作業フォルダ" IsChecked="{Binding ItemEquivalenceWorkingDirectory}" />
          <CheckBox Content="パラメータ引数" IsChecked="{Binding ItemEquivalenceArguments}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </DockPanel>
</Window>
